{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sp00ky.cloud/schema/sp00ky.schema.json",
  "title": "sp00ky.yml",
  "description": "Configuration file for Sp00ky — an offline-first, real-time sync framework built on SurrealDB.",
  "type": "object",
  "properties": {
    "slug": {
      "type": "string",
      "description": "Cloud project slug used by `spooky cloud` commands. Must be unique across Sp00ky Cloud.",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "mode": {
      "type": "string",
      "description": "Deployment mode.",
      "enum": ["sidecar", "singlenode"],
      "default": "sidecar"
    },
    "surrealdb": {
      "description": "SurrealDB configuration. Can be a version string (e.g. \"v3.0.0\") or a full config object.",
      "oneOf": [
        {
          "type": "string",
          "description": "SurrealDB Docker image version tag (e.g. \"v3.0.0\")."
        },
        {
          "$ref": "#/$defs/surrealdbConfig"
        }
      ]
    },
    "version": {
      "description": "Sp00ky service versions. A single string sets both SSP and Scheduler. An object allows individual control.",
      "oneOf": [
        {
          "type": "string",
          "description": "Version tag applied to both SSP and Scheduler (e.g. \"canary\", \"v1.0.0\")."
        },
        {
          "type": "object",
          "description": "Individual version tags for SSP and Scheduler.",
          "properties": {
            "ssp": {
              "type": "string",
              "description": "SSP (Spooky Sidecar Processor) image version tag.",
              "default": "canary"
            },
            "scheduler": {
              "type": "string",
              "description": "Scheduler image version tag.",
              "default": "canary"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "schema": {
      "description": "Schema directory or explicit paths. A string is treated as the base directory (convention: schema/src/schema.surql, schema/migrations/, schema/src/buckets/).",
      "oneOf": [
        {
          "type": "string",
          "description": "Base directory for schema files. Sub-paths are derived by convention."
        },
        {
          "type": "object",
          "description": "Explicit paths for schema, migrations, and buckets.",
          "properties": {
            "schema": {
              "type": "string",
              "description": "Path to the main SurrealQL schema file.",
              "default": "src/schema.surql"
            },
            "migrations": {
              "type": "string",
              "description": "Path to the migrations directory.",
              "default": "migrations"
            },
            "bucketsDir": {
              "type": "string",
              "description": "Path to the buckets directory.",
              "default": "src/buckets"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "backends": {
      "type": "object",
      "description": "Backend service definitions. Each key is the backend name.",
      "additionalProperties": {
        "$ref": "#/$defs/backendConfig"
      }
    },
    "buckets": {
      "type": "array",
      "description": "List of SurrealQL bucket definition files.",
      "items": {
        "type": "string"
      }
    },
    "clientTypes": {
      "type": "array",
      "description": "Generated client type configurations.",
      "items": {
        "$ref": "#/$defs/clientTypeConfig"
      }
    },
    "devApp": {
      "type": "string",
      "description": "Dev command to start the frontend app during `spooky dev`."
    },
    "frontend": {
      "$ref": "#/$defs/frontendDeployConfig"
    },
    "deployment": {
      "$ref": "#/$defs/deploymentConfig"
    },
    "cloudApi": {
      "type": "string",
      "description": "Override the Sp00ky Cloud API endpoint (e.g. for staging).",
      "examples": ["https://api-staging.sp00ky.cloud"]
    }
  },
  "additionalProperties": false,
  "$defs": {
    "surrealdbConfig": {
      "type": "object",
      "description": "Full SurrealDB configuration.",
      "properties": {
        "version": {
          "type": "string",
          "description": "SurrealDB Docker image version tag.",
          "default": "v3.0.0"
        },
        "namespace": {
          "type": "string",
          "description": "SurrealDB namespace.",
          "default": "main"
        },
        "database": {
          "type": "string",
          "description": "SurrealDB database name.",
          "default": "main"
        },
        "hosting": {
          "type": "string",
          "description": "Whether SurrealDB is hosted on Sp00ky Cloud or externally.",
          "enum": ["cloud", "external"],
          "default": "cloud"
        },
        "endpoint": {
          "type": "string",
          "description": "SurrealDB endpoint URL. Required when hosting is \"external\".",
          "examples": ["https://api.example.com"]
        },
        "username": {
          "type": "string",
          "description": "SurrealDB username.",
          "default": "root"
        },
        "password": {
          "type": "string",
          "description": "SurrealDB password.",
          "default": "root"
        }
      },
      "if": {
        "properties": { "hosting": { "const": "external" } },
        "required": ["hosting"]
      },
      "then": {
        "required": ["endpoint"]
      },
      "additionalProperties": false
    },
    "backendConfig": {
      "type": "object",
      "description": "Configuration for a single backend service.",
      "required": ["spec", "method"],
      "properties": {
        "hosting": {
          "type": "string",
          "description": "Whether this backend is deployed to Sp00ky Cloud or self-hosted.",
          "enum": ["cloud", "external"],
          "default": "cloud"
        },
        "type": {
          "type": "string",
          "description": "Backend type.",
          "enum": ["http"]
        },
        "spec": {
          "type": "string",
          "description": "Path to the OpenAPI specification file that defines API routes."
        },
        "baseUrl": {
          "type": "string",
          "description": "Base URL of the HTTP backend service (used for local development).",
          "examples": ["https://api.example.com"]
        },
        "auth": {
          "$ref": "#/$defs/authConfig"
        },
        "method": {
          "$ref": "#/$defs/backendMethod"
        },
        "dev": {
          "$ref": "#/$defs/backendDevConfig"
        },
        "deploy": {
          "$ref": "#/$defs/backendDeployConfig"
        }
      },
      "if": {
        "properties": { "hosting": { "const": "external" } },
        "required": ["hosting"]
      },
      "then": {
        "required": ["baseUrl"]
      },
      "additionalProperties": false
    },
    "authConfig": {
      "type": "object",
      "description": "Authentication configuration for a backend service.",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "description": "Authentication type.",
          "enum": ["token"]
        },
        "token": {
          "type": "string",
          "description": "Bearer token included in HTTP requests to this backend. Supports environment variable substitution (e.g. ${API_TOKEN})."
        }
      },
      "additionalProperties": false
    },
    "backendMethod": {
      "type": "object",
      "description": "Defines how the backend is triggered.",
      "required": ["type", "schema"],
      "properties": {
        "type": {
          "type": "string",
          "description": "Method type for calling the backend.",
          "enum": ["outbox"]
        },
        "table": {
          "type": "string",
          "description": "SurrealDB outbox table name (e.g. \"jobs_agent\")."
        },
        "schema": {
          "type": "string",
          "description": "Path to the SurrealQL schema file that defines the job table structure."
        }
      },
      "additionalProperties": false
    },
    "backendDevConfig": {
      "description": "Dev server configuration. Can be a raw shell command string or a typed object.",
      "oneOf": [
        {
          "type": "string",
          "description": "Raw shell command to start the dev server (e.g. \"node server.js\")."
        },
        {
          "type": "object",
          "description": "Typed dev server configuration.",
          "required": ["type"],
          "oneOf": [
            { "$ref": "#/$defs/devConfigNpm" },
            { "$ref": "#/$defs/devConfigDocker" },
            { "$ref": "#/$defs/devConfigUv" }
          ]
        }
      ]
    },
    "devConfigNpm": {
      "type": "object",
      "description": "Run an npm/pnpm script as the dev server.",
      "required": ["type", "script"],
      "properties": {
        "type": {
          "type": "string",
          "const": "npm"
        },
        "script": {
          "type": "string",
          "description": "npm script name to run (e.g. \"dev\")."
        },
        "workdir": {
          "type": "string",
          "description": "Working directory relative to sp00ky.yml."
        },
        "env-file": {
          "type": "string",
          "description": "Path to a dotenv-style env file, resolved relative to the project root."
        }
      },
      "additionalProperties": false
    },
    "devConfigDocker": {
      "type": "object",
      "description": "Build and run a Dockerfile as the dev server.",
      "required": ["type", "file"],
      "properties": {
        "type": {
          "type": "string",
          "const": "docker"
        },
        "file": {
          "type": "string",
          "description": "Dockerfile to build."
        },
        "workdir": {
          "type": "string",
          "description": "Build context directory relative to sp00ky.yml."
        },
        "port": {
          "type": "string",
          "description": "Port mapping (e.g. \"3000:3000\")."
        },
        "env": {
          "type": "array",
          "description": "Environment variables in KEY=VALUE format.",
          "items": { "type": "string" }
        },
        "env-file": {
          "type": "string",
          "description": "Path to a dotenv-style env file, passed via Docker's --env-file flag."
        }
      },
      "additionalProperties": false
    },
    "devConfigUv": {
      "type": "object",
      "description": "Run a Python script via uv as the dev server.",
      "required": ["type", "script"],
      "properties": {
        "type": {
          "type": "string",
          "const": "uv"
        },
        "script": {
          "type": "string",
          "description": "Python script to run via `uv run` (e.g. \"server.py\")."
        },
        "workdir": {
          "type": "string",
          "description": "Working directory relative to sp00ky.yml."
        },
        "env-file": {
          "type": "string",
          "description": "Path to a dotenv-style env file, resolved relative to the project root."
        }
      },
      "additionalProperties": false
    },
    "backendDeployConfig": {
      "type": "object",
      "description": "Deployment configuration for a backend service on Sp00ky Cloud.",
      "properties": {
        "dockerfile": {
          "type": "string",
          "description": "Dockerfile path relative to sp00ky.yml."
        },
        "context": {
          "type": "string",
          "description": "Docker build context directory relative to sp00ky.yml. Defaults to the project root."
        },
        "port": {
          "type": "integer",
          "description": "Port the service listens on inside the container.",
          "default": 8080,
          "minimum": 1,
          "maximum": 65535
        },
        "expose": {
          "type": "boolean",
          "description": "Expose the backend publicly via {slug}-{name}.spky.cloud.",
          "default": false
        },
        "resources": {
          "$ref": "#/$defs/resources"
        },
        "env": {
          "type": "array",
          "description": "Environment variables in KEY=VALUE format passed to the VM.",
          "items": { "type": "string" }
        },
        "env-file": {
          "type": "string",
          "description": "Path to a dotenv-style env file (relative to sp00ky.yml). Variables are injected into the deployed container."
        },
        "healthcheck": {
          "type": "string",
          "description": "Health check HTTP path for the scheduler to ping (e.g. \"/health\")."
        },
        "timeout": {
          "type": "integer",
          "description": "HTTP request timeout in seconds for the job runner when calling this backend. Increase for long-running operations like LLM inference.",
          "default": 10,
          "minimum": 1,
          "maximum": 3600
        },
        "timeout_overridable": {
          "type": "boolean",
          "description": "When true, the frontend can override the timeout per-job via the `timeout` option in `db.run()`. When false, the deploy-time timeout is always used.",
          "default": false
        }
      },
      "additionalProperties": false
    },
    "resources": {
      "type": "object",
      "description": "Resource allocation for a VM.",
      "properties": {
        "vcpus": {
          "type": "integer",
          "description": "Number of virtual CPUs.",
          "default": 1,
          "minimum": 1
        },
        "memory": {
          "type": "integer",
          "description": "Memory in MB.",
          "default": 512,
          "minimum": 128
        },
        "disk": {
          "type": "integer",
          "description": "Disk size in GB.",
          "default": 5,
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "clientTypeConfig": {
      "type": "object",
      "description": "Generated client type configuration.",
      "required": ["format", "output"],
      "properties": {
        "format": {
          "type": "string",
          "description": "Output format for generated types.",
          "enum": ["typescript", "dart"]
        },
        "output": {
          "type": "string",
          "description": "Output file path for the generated types."
        }
      },
      "additionalProperties": false
    },
    "frontendDeployConfig": {
      "type": "object",
      "description": "Frontend deployment configuration for Sp00ky Cloud.",
      "required": ["dockerfile"],
      "properties": {
        "dockerfile": {
          "type": "string",
          "description": "Dockerfile path relative to sp00ky.yml."
        },
        "context": {
          "type": "string",
          "description": "Docker build context directory relative to sp00ky.yml. Defaults to the project root."
        },
        "port": {
          "type": "integer",
          "description": "Port the frontend listens on inside the container.",
          "default": 3000,
          "minimum": 1,
          "maximum": 65535
        },
        "resources": {
          "$ref": "#/$defs/resources"
        },
        "env": {
          "type": "array",
          "description": "Environment variables in KEY=VALUE format.",
          "items": { "type": "string" }
        },
        "env-file": {
          "type": "string",
          "description": "Path to a dotenv-style env file (relative to sp00ky.yml)."
        }
      },
      "additionalProperties": false
    },
    "deploymentConfig": {
      "type": "object",
      "description": "Deployment-level configuration for Sp00ky Cloud.",
      "properties": {
        "ssp_count": {
          "type": "integer",
          "description": "Number of SSP instances to provision. Overrides the plan default.",
          "minimum": 1,
          "maximum": 20
        },
        "backup": {
          "$ref": "#/$defs/backupConfig"
        }
      },
      "additionalProperties": false
    },
    "backupConfig": {
      "type": "object",
      "description": "Automated backup configuration.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable automated backups.",
          "default": false
        },
        "schedule": {
          "type": "string",
          "description": "Cron schedule expression (e.g. \"0 2 * * *\" for 2am daily)."
        },
        "retention": {
          "type": "integer",
          "description": "Number of backups to retain.",
          "minimum": 1
        },
        "bucket_url": {
          "type": "string",
          "description": "External S3-compatible bucket URL. If set, MinIO is skipped.",
          "examples": ["https://api.example.com"]
        },
        "credentials_env_file": {
          "type": "string",
          "description": "Path to env file with BACKUP_ACCESS_KEY and BACKUP_SECRET_KEY."
        }
      },
      "additionalProperties": false
    }
  }
}
