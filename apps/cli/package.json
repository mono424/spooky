{
  "name": "@spooky-sync/cli",
  "version": "0.0.1-canary.64",
  "description": "Generate TypeScript/Dart types from SurrealDB schema files",
  "type": "module",
  "main": "./dist/syncgen.cjs",
  "module": "./dist/syncgen.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "spky": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/syncgen.js",
      "require": "./dist/syncgen.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "devtools-mcp",
    "templates/cookbook",
    "AGENTS.md"
  ],
  "scripts": {
    "dev": "vite",
    "build:rust": "cargo build --release",
    "build:vite": "vite build",
    "build:types": "tsc --emitDeclarationOnly --declaration --declarationDir dist",
    "build:devtools-mcp": "cd ../devtools-mcp && npm run build && cp -r dist ../cli/devtools-mcp",
    "build:js": "npm run build:vite && npm run build:types",
    "build": "npm run build:rust && npm run build:devtools-mcp && npm run build:js",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "eslint src",
    "prepare": "test -f ./dist/cli.js || npm run build"
  },
  "keywords": [
    "surrealdb",
    "code-generation",
    "typescript",
    "dart",
    "schema"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mono424/sp00ky.git",
    "directory": "apps/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "vitest": "^1.0.0"
  }
}
