{
  "name": "{{PROJECT_NAME}}",
  "private": true,
  "scripts": {
    "dev": "spky dev",
    "dev:app": "pnpm --filter @{{PROJECT_NAME}}/app dev",
    "build": "spky generate && pnpm --filter @{{PROJECT_NAME}}/app build",
    "generate": "spky generate",
    "migrate:create": "spky migrate create",
    "migrate:apply": "spky migrate apply --url http://localhost:8666",
    "migrate:status": "spky migrate status --url http://localhost:8666"
  },
  "devDependencies": {
    "@spooky-sync/cli": "{{VERSION}}"
  },
  "pnpm": {
    "overrides": {
      "@spooky-sync/query-builder": "{{VERSION}}",
      "@spooky-sync/core": "{{VERSION}}",
      "@spooky-sync/ssp-wasm": "{{VERSION}}"
    }
  }
}
