{
  "name": "{{PROJECT_NAME}}",
  "private": true,
  "scripts": {
    "dev": "spooky dev",
    "dev:app": "pnpm --filter @{{PROJECT_NAME}}/app dev",
    "build": "spooky generate && pnpm --filter @{{PROJECT_NAME}}/app build",
    "generate": "spooky generate",
    "migrate:create": "spooky migrate create",
    "migrate:apply": "spooky migrate apply --url http://localhost:8666",
    "migrate:status": "spooky migrate status --url http://localhost:8666"
  },
  "devDependencies": {
    "@spooky-sync/cli": "{{VERSION}}"
  },
  "pnpm": {
    "overrides": {
      "@spooky-sync/query-builder": "{{VERSION}}",
      "@spooky-sync/core": "{{VERSION}}",
      "@spooky-sync/ssp-wasm": "{{VERSION}}"
    }
  }
}
