---
import { basePath } from '../config/nav';

const BASE = import.meta.env.BASE_URL;
const assetUrl = (p: string) => `${BASE}${p.replace(/^\/+/, '')}`;
---

<footer class="site-footer">
  <div class="site-footer-inner">
    <div class="site-footer-mark-box" aria-label="sp00ky">
      <img class="site-footer-mark-glyph" src={assetUrl('footer-mark-00.svg')} alt="" />
    </div>

    <nav class="site-footer-nav">
      <div class="site-footer-col">
        <h4>The Haunt</h4>
        <a href="/">Home</a>
        <a href={`${basePath}/docs`}>Docs</a>
        <a href="/features">Features</a>
        <a href="/cloud">Cloud</a>
      </div>
      <div class="site-footer-col">
        <h4>The Crypt</h4>
        <a href="/pricing">Pricing</a>
        <a href="/team">About</a>
        <a href="/terms">Terms of Use</a>
        <a href="/privacy">Privacy</a>
      </div>
      <div class="site-footer-col">
        <h4>The Coven</h4>
        <a href="https://github.com/mono424/sp00ky" target="_blank" rel="noopener">GitHub</a>
        <a href="https://www.reddit.com/r/surrealdb/comments/1srlxvf/sp00ky_sync_engine/" target="_blank" rel="noopener">Reddit</a>
        <a href="https://discord.com/channels/902568124350599239/1454620262526877696" target="_blank" rel="noopener">Discord</a>
      </div>
    </nav>
  </div>

  <div class="site-footer-wordmark" aria-hidden="true">
    <img src={assetUrl('logo-footer.svg')} alt="" />
  </div>

  <div class="site-footer-bottom">
    <span>Sp00ky © 2026</span>
    <span>Made with ghosts</span>
  </div>
</footer>
