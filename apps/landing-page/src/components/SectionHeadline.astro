---
interface Props {
  title: string;
  description?: string;
  align?: 'left' | 'center';
  badge?: string;
}

const { title, description, badge } = Astro.props;
---

<div class="mb-16 text-center relative">
  {badge && (
    <div class="mb-4">
      <span class="inline-block px-3 py-1 text-[10px] font-medium text-text-muted bg-white/5 border border-white/8 rounded-full uppercase tracking-widest">
        {badge}
      </span>
    </div>
  )}

  <h2 class="text-section font-semibold text-text-primary mb-6">
    {title}
  </h2>
  {
    description ? (
      <p class="text-text-tertiary max-w-2xl mx-auto text-body leading-relaxed">
        <Fragment set:html={description} />
      </p>
    ) : (
      <div class="text-text-tertiary max-w-2xl mx-auto text-body leading-relaxed">
        <slot />
      </div>
    )
  }
</div>
