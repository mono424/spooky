---
import { basePath } from '../config/nav';
import { MegaMenu } from './MegaMenu';

interface Props {
  activePath?: string;
}

const { activePath = '/' } = Astro.props;

const BASE = import.meta.env.BASE_URL;
const assetUrl = (p: string) => `${BASE}${p.replace(/^\/+/, '')}`;

const links = [
  { label: 'Pricing', href: '/pricing' },
  { label: 'Docs', href: `${basePath}/docs` },
];

const logoSrc = assetUrl('logo.svg');
const faviconSrc = assetUrl('favicon.svg');
---

<header class="nav-root">
  <div class="nav-inner">
    <a class="nav-logo" href="/" id="nav-logo" data-logo-src={logoSrc} data-favicon-src={faviconSrc}>
      <img src={logoSrc} alt="sp00ky" />
    </a>

    <div class="nav-links-wrap">
      <div class="nav-links">
        <MegaMenu client:load />
        {
          links.map((l) => (
            <a
              class={`nav-link${activePath === l.href ? ' active' : ''}`}
              href={l.href}
            >
              {l.label}
            </a>
          ))
        }
      </div>
    </div>

    <div class="nav-right">
      <a
        class="nav-github"
        href="https://github.com/mono424/sp00ky"
        target="_blank"
        rel="noopener"
        aria-label="GitHub"
      >
        <svg viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48l-.01-1.71c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.46-1.11-1.46-.91-.62.07-.61.07-.61 1 .07 1.53 1.03 1.53 1.03.89 1.53 2.34 1.09 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.56-1.11-4.56-4.95 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02a9.58 9.58 0 0 1 5 0c1.9-1.29 2.75-1.02 2.75-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.68 0 3.85-2.34 4.69-4.57 4.94.36.31.68.92.68 1.86l-.01 2.76c0 .27.18.58.69.48A10 10 0 0 0 12 2z" />
        </svg>
      </a>
      <button
        id="mobile-menu-btn"
        class="nav-mobile-toggle"
        aria-label="Toggle menu"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="nav-mobile-menu hidden">
    <a href="/features">Features</a>
    {links.map((l) => <a href={l.href}>{l.label}</a>)}
    <a href="https://github.com/mono424/sp00ky" target="_blank" rel="noopener">GitHub</a>
  </div>
</header>

<div
  id="nav-logo-menu"
  class="nav-logo-menu hidden"
  role="menu"
  aria-label="Logo actions"
>
  <button type="button" role="menuitem" data-action="open">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M14 4 h6 v6"></path>
      <path d="M10 14 L20 4"></path>
      <path d="M20 14 v6 h-6"></path>
      <path d="M4 10 v10 h10"></path>
    </svg>
    <span>Open logo in new tab</span>
  </button>
  <button type="button" role="menuitem" data-action="copy">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <rect x="9" y="9" width="11" height="11" rx="2"></rect>
      <path d="M5 15 H4 a2 2 0 0 1 -2 -2 V4 a2 2 0 0 1 2 -2 h9 a2 2 0 0 1 2 2 v1"></path>
    </svg>
    <span id="nav-logo-copy-label">Copy logo</span>
  </button>
  <div class="nav-logo-menu-sep"></div>
  <button type="button" role="menuitem" data-action="download-logo">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 4 v12"></path>
      <path d="M6 12 l6 6 6 -6"></path>
      <path d="M4 20 h16"></path>
    </svg>
    <span>Download logo (SVG)</span>
  </button>
  <button type="button" role="menuitem" data-action="download-favicon">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 4 v12"></path>
      <path d="M6 12 l6 6 6 -6"></path>
      <path d="M4 20 h16"></path>
    </svg>
    <span>Download favicon (SVG)</span>
  </button>
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  if (btn && mobileMenu) {
    btn.addEventListener('click', () => mobileMenu.classList.toggle('hidden'));
  }

  const logo = document.getElementById('nav-logo') as HTMLAnchorElement | null;
  const logoMenu = document.getElementById('nav-logo-menu');
  const copyLabel = document.getElementById('nav-logo-copy-label');

  if (logo && logoMenu) {
    const logoSrc = logo.dataset.logoSrc || '/logo.svg';
    const faviconSrc = logo.dataset.faviconSrc || '/favicon.svg';

    const openMenu = (x: number, y: number) => {
      logoMenu.classList.remove('hidden');
      // Clamp within viewport
      const rect = logoMenu.getBoundingClientRect();
      const maxX = window.innerWidth - rect.width - 8;
      const maxY = window.innerHeight - rect.height - 8;
      logoMenu.style.left = `${Math.min(x, maxX)}px`;
      logoMenu.style.top = `${Math.min(y, maxY)}px`;
    };

    const closeMenu = () => {
      logoMenu.classList.add('hidden');
    };

    logo.addEventListener('contextmenu', (e) => {
      e.preventDefault();
      openMenu(e.clientX, e.clientY);
    });

    document.addEventListener('click', (e) => {
      if (!logoMenu.contains(e.target as Node)) closeMenu();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeMenu();
    });
    window.addEventListener('scroll', closeMenu, { passive: true });
    window.addEventListener('resize', closeMenu);

    const triggerDownload = (src: string, filename: string) => {
      const a = document.createElement('a');
      a.href = src;
      a.download = filename;
      a.rel = 'noopener';
      document.body.appendChild(a);
      a.click();
      a.remove();
    };

    const copyLogo = async () => {
      if (!copyLabel) return;
      const original = copyLabel.textContent;
      try {
        const res = await fetch(logoSrc);
        const svgText = await res.text();

        // Try image/png via canvas first (best paste compatibility)
        let pngCopied = false;
        try {
          const img = new Image();
          img.crossOrigin = 'anonymous';
          const blobUrl = URL.createObjectURL(
            new Blob([svgText], { type: 'image/svg+xml' })
          );
          await new Promise<void>((resolve, reject) => {
            img.onload = () => resolve();
            img.onerror = reject;
            img.src = blobUrl;
          });
          const canvas = document.createElement('canvas');
          canvas.width = img.naturalWidth || 512;
          canvas.height = img.naturalHeight || 512;
          const ctx = canvas.getContext('2d');
          ctx?.drawImage(img, 0, 0);
          URL.revokeObjectURL(blobUrl);
          const pngBlob: Blob | null = await new Promise((r) => canvas.toBlob(r, 'image/png'));
          if (pngBlob && 'ClipboardItem' in window) {
            await navigator.clipboard.write([
              new ClipboardItem({ 'image/png': pngBlob }),
            ]);
            pngCopied = true;
          }
        } catch {
          // fall through
        }

        if (!pngCopied) {
          await navigator.clipboard.writeText(svgText);
        }

        copyLabel.textContent = 'Copied';
        setTimeout(() => {
          copyLabel.textContent = original;
        }, 1600);
      } catch {
        copyLabel.textContent = 'Copy failed';
        setTimeout(() => {
          copyLabel.textContent = original;
        }, 1600);
      }
    };

    logoMenu.addEventListener('click', async (e) => {
      const target = (e.target as HTMLElement).closest('button[data-action]') as HTMLButtonElement | null;
      if (!target) return;
      const action = target.dataset.action;
      if (action === 'open') {
        window.open(logoSrc, '_blank', 'noopener');
        closeMenu();
      } else if (action === 'copy') {
        await copyLogo();
      } else if (action === 'download-logo') {
        triggerDownload(logoSrc, 'sp00ky-logo.svg');
        closeMenu();
      } else if (action === 'download-favicon') {
        triggerDownload(faviconSrc, 'sp00ky-favicon.svg');
        closeMenu();
      }
    });
  }
</script>
