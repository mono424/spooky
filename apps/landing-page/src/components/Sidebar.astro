---
import { basePath, docsNav as nav } from '../config/nav';

const currentPath = Astro.url.pathname;
---

<nav class="space-y-6">
  {
    nav.map((group, index) => {
      const hasActivePage = group.links.some(
        (link) =>
          currentPath === link.href ||
          (link.href !== `${basePath}/docs` && currentPath.startsWith(link.href))
      );
      const isOpen = hasActivePage;
      return (
      <details open={isOpen} name="docs-sidebar" class="group">
        <summary class="flex items-center justify-between cursor-pointer list-none text-sm font-medium text-text-primary mb-2 px-2 hover:opacity-80 select-none">
          {group.title}
          <svg
            class="w-4 h-4 transition-transform group-open:rotate-180 text-text-muted"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 9l-7 7-7-7"
            />
          </svg>
        </summary>
        <ul class="space-y-0.5 relative border-l border-white/10 ml-2 pl-2">
          {group.links.map((link) => {
            const isActive =
              currentPath === link.href ||
              (link.href !== `${basePath}/docs` && currentPath.startsWith(link.href));
            return (
              <li>
                <a
                  href={link.href}
                  class:list={[
                    'flex items-center gap-2 px-2 py-1.5 text-sm rounded-sm transition-colors border border-transparent',
                    isActive
                      ? 'text-white bg-white/5 font-medium border-white/10'
                      : 'text-zinc-400 hover:text-zinc-200 hover:bg-white/5',
                  ]}
                >
                  {isActive && <span class="w-1.5 h-1.5 bg-white rounded-full" />}
                  <span>{link.text}</span>
                  {link.experimental && (
                    <svg
                      class="ml-auto w-3.5 h-3.5 text-amber-300 shrink-0"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      viewBox="0 0 24 24"
                      aria-label="Experimental"
                    >
                      <title>Experimental</title>
                      <path d="M9 3h6" />
                      <path d="M10 3v6.5L4.5 19a2 2 0 0 0 1.7 3h11.6a2 2 0 0 0 1.7-3L14 9.5V3" />
                      <path d="M7 14h10" />
                    </svg>
                  )}
                </a>
              </li>
            );
          })}
        </ul>
      </details>
    );})
  }
</nav>

<script>
  // Accordion fallback for browsers without <details name=""> support
  document.querySelectorAll('details[name="docs-sidebar"]').forEach((details) => {
    details.addEventListener('toggle', () => {
      if (details.open) {
        document.querySelectorAll('details[name="docs-sidebar"]').forEach((other) => {
          if (other !== details) other.open = false;
        });
      }
    });
  });
</script>

<style>
  /* Remove default details marker */
  details > summary {
    list-style: none;
  }
  details > summary::-webkit-details-marker {
    display: none;
  }
</style>
