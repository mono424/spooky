---
// src/pages/index.astro
// oxlint-disable-next-line no-unassigned-import
import '../styles/global.css';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { HeroStack } from '../components/HeroStack';
import { FloatingGhosts } from '../components/FloatingGhosts';
import { FeatureGrid } from '../components/UnderTheHood';
import { basePath } from '../config/nav';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="sp00ky - A SurrealDB native Sync Engine" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.site} />
    <meta property="og:title" content="sp00ky: The SurrealDB Native Real-Time Sync Engine" />
    <meta
      property="og:description"
      content="Build local-first, offline-ready applications with sp00ky. Use the power of SurrealDB to synchronize data instantly across devices."
    />
    <meta property="og:image" content={new URL('/social-card.png', Astro.site)} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.site} />
    <meta property="twitter:title" content="sp00ky: The SurrealDB Native Real-Time Sync Engine" />
    <meta
      property="twitter:description"
      content="Build local-first, offline-ready applications with sp00ky. Use the power of SurrealDB to synchronize data instantly across devices."
    />
    <meta property="twitter:image" content={new URL('/social-card.png', Astro.site)} />
    <link rel="help" type="text/markdown" href="/llm.txt" title="LLM Info" />
    <title>sp00ky</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <SiteNav activePath="/" />

    <main class="flex-1">
      <!-- HERO -->
      <section id="home" class="hero-new">
        <div class="hero-new-bg">
          <FloatingGhosts client:idle count={14} />
        </div>

        <div class="hero-new-inner">
          <div class="hero-left">
            <div class="hero-eyebrow">
              <span class="badge">canary</span>
              Pre-Alpha · open source
            </div>

            <h1 class="hero-headline">
              Focus on Product.<br /><span class="accent">We Handle Sync.</span>
            </h1>

            <p class="hero-sub">
              Ship your app with real-time sync, offline support, and full type safety. No extra
              work required.
            </p>

            <div class="hero-install">
              <span class="prompt">$</span>
              <span class="cmd">npx @spooky-sync/cli@canary create</span>
              <button class="copy-btn" id="hero-copy-btn" aria-label="Copy install command">
                <svg
                  id="hero-copy-icon"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <rect x="9" y="9" width="11" height="11" rx="2"></rect>
                  <path d="M5 15 H4 a2 2 0 0 1 -2 -2 V4 a2 2 0 0 1 2 -2 h9 a2 2 0 0 1 2 2 v1"></path>
                </svg>
                <svg
                  id="hero-check-icon"
                  class="hidden"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M20 6 L9 17 l-5 -5"></path>
                </svg>
              </button>
            </div>

            <div class="hero-ctas">
              <a href={`${basePath}/docs`} class="hero-btn hero-btn-primary">
                Get Started
              </a>
              <a
                href="https://github.com/mono424/sp00ky"
                target="_blank"
                rel="noopener"
                class="hero-btn hero-btn-ghost"
              >
                View on Github
              </a>
            </div>
          </div>

          <div class="hero-right">
            <HeroStack client:load />
          </div>
        </div>
      </section>

      <!-- Local First copy + 4-up FeatureGrid + Try sp00ky card -->
      <section class="pt-12 pb-16 md:pb-32 border-b border-white/10">
        <div class="max-w-7xl mx-auto px-4">
          <FeatureGrid client:visible />
        </div>

        <!-- Try Out Now — card style -->
        <div class="max-w-7xl mx-auto px-4 mt-16 md:mt-24">
          <div class="try-out-btn group relative rounded-2xl border border-white/[0.08] bg-[#111318] overflow-hidden cursor-pointer transition-all duration-300 hover:border-white/[0.14]">
            <div class="flex flex-col md:flex-row items-stretch min-h-[200px]">
              <div class="relative z-10 flex flex-col justify-between p-8 md:p-10 md:w-[45%]">
                <div>
                  <h3 class="text-xl font-semibold text-white/90 mb-2">Experimental Demo</h3>
                  <p class="text-sm text-white/40 leading-relaxed max-w-[260px]">
                    Explore a live app built with sp00ky. Powered by CRDTs, file buckets, and real-time sync.
                  </p>
                </div>
                <div class="mt-6">
                  <span class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white/70 rounded-lg border border-white/[0.1] bg-white/[0.04] group-hover:bg-white/[0.08] group-hover:text-white group-hover:border-white/[0.18] transition-all duration-300">
                    Try it now
                    <svg
                      class="w-3.5 h-3.5 -rotate-[0deg] group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform duration-300"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10"></path>
                    </svg>
                  </span>
                </div>
              </div>
              <div class="relative flex-1 min-h-[160px] md:min-h-0">
                <div class="absolute inset-0 tryout-grid opacity-[0.35]"></div>
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="flex flex-col items-center gap-5 opacity-40 group-hover:opacity-60 transition-opacity duration-500">
                    <img src="/logo.svg" alt="sp00ky" class="w-40 md:w-48" />
                    <span class="text-[11px] font-mono uppercase tracking-[0.25em] text-white/50">threads demo</span>
                  </div>
                </div>
                <div class="hidden md:flex absolute right-0 top-0 bottom-0 w-10 items-center justify-center">
                  <span class="text-[10px] font-mono uppercase tracking-[0.3em] text-white/15 whitespace-nowrap" style="writing-mode: vertical-rl;">Experimental Preview</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- CTA SECTION -->
      <section class="py-16 md:py-32 border-t border-white/5 bg-black text-center relative overflow-hidden">
        <div class="max-w-4xl mx-auto px-4 relative z-10">
          <h2 class="text-section md:text-hero font-semibold mb-8 text-text-primary">
            Ready to build something amazing?
          </h2>
          <p class="text-text-tertiary text-body-lg mb-12 max-w-2xl mx-auto leading-relaxed">
            Start building local-first, offline-ready applications today. Dive into the documentation
            to learn more about the architecture and implementation details.
          </p>
          <a
            href={`${basePath}/docs`}
            class="inline-flex items-center gap-3 bg-white text-black px-8 py-3 font-medium text-lg rounded-lg transition-colors duration-150 hover:bg-white/90 group"
          >
            <span>Get Started</span>
            <svg
              class="w-5 h-5 transition-transform duration-200 group-hover:translate-x-1"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </a>
        </div>
      </section>
    </main>

    <SiteFooter />

    <!-- Try Out Now fullscreen iframe overlay -->
    <div id="tryout-overlay" class="fixed inset-0 z-[100] hidden">
      <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" id="tryout-backdrop"></div>
      <div class="relative z-10 flex flex-col w-full h-full p-3 md:p-6">
        <div class="flex justify-end mb-2">
          <button
            id="tryout-close"
            class="flex items-center gap-2 px-4 py-2 text-sm font-medium text-text-tertiary hover:text-white bg-white/10 hover:bg-white/20 rounded-lg transition-all duration-200"
            aria-label="Close demo"
          >
            <span>Close</span>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>
        <iframe
          id="tryout-iframe"
          class="flex-1 w-full rounded-xl border border-white/10 bg-black"
          title="sp00ky Demo"
          allowfullscreen
        ></iframe>
      </div>
    </div>

    <script>
      // Hero install copy button
      const copyBtn = document.getElementById('hero-copy-btn');
      const copyIcon = document.getElementById('hero-copy-icon');
      const checkIcon = document.getElementById('hero-check-icon');
      if (copyBtn && copyIcon && checkIcon) {
        copyBtn.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText('npx @spooky-sync/cli@canary create');
          } catch {
            /* ignore */
          }
          copyIcon.classList.add('hidden');
          checkIcon.classList.remove('hidden');
          setTimeout(() => {
            copyIcon.classList.remove('hidden');
            checkIcon.classList.add('hidden');
          }, 1600);
        });
      }

      // Try sp00ky overlay
      const overlay = document.getElementById('tryout-overlay');
      const iframe = document.getElementById('tryout-iframe') as HTMLIFrameElement;
      const closeBtn = document.getElementById('tryout-close');
      const backdrop = document.getElementById('tryout-backdrop');

      function openTryout() {
        if (!overlay || !iframe) return;
        iframe.src = 'https://threads-app.stg.spky.cloud/';
        overlay.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }

      function closeTryout() {
        if (!overlay || !iframe) return;
        overlay.classList.add('hidden');
        iframe.src = '';
        document.body.style.overflow = '';
      }

      document.querySelectorAll('.try-out-btn').forEach((btn) => {
        btn.addEventListener('click', openTryout);
      });

      closeBtn?.addEventListener('click', closeTryout);
      backdrop?.addEventListener('click', closeTryout);

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeTryout();
      });
    </script>
  </body>

  <script>
    // Animated favicon (floating ghost)
    const ghostSVG = `
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" fill="none">
      <style>
        .bg { fill: #FFFFFF; }
        .ghost { fill: #000000; }
        .eyes { fill: #FFFFFF; }
        @media (prefers-color-scheme: dark) {
          .bg { fill: #000000; }
          .ghost { fill: #FFFFFF; }
          .eyes { fill: #000000; }
        }
      </style>
      <path class="ghost" d="M6 10V28L10 24L14 28L18 24L22 28L26 24V10C26 4.47715 21.5228 0 16 0C10.4772 0 6 4.47715 6 10Z"/>
      <rect class="eyes" x="10" y="8" width="4" height="4"/>
      <rect class="eyes" x="18" y="8" width="4" height="4"/>
    </svg>`;

    const canvas = document.createElement('canvas');
    canvas.width = 32;
    canvas.height = 32;
    const ctx = canvas.getContext('2d');

    const img = new Image();
    img.src = 'data:image/svg+xml;base64,' + btoa(ghostSVG);

    let link = document.querySelector("link[rel~='icon']") as HTMLLinkElement;
    if (!link) {
      link = document.createElement('link');
      link.rel = 'icon';
      document.head.appendChild(link);
    }

    img.addEventListener('load', function () {
      const start = performance.now();
      function step(timestamp: number) {
        const elapsed = timestamp - start;
        const yOffset = (1 - Math.cos((elapsed / 3000) * 2 * Math.PI)) * 1.5;
        ctx?.clearRect(0, 0, 32, 32);
        ctx?.drawImage(img, 0, yOffset, 32, 32);
        link.href = canvas.toDataURL('image/png');
        requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    });
  </script>

  <style>
    /* Try Out Now — grid pattern */
    .tryout-grid {
      background-image:
        linear-gradient(rgba(255, 255, 255, 0.06) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.06) 1px, transparent 1px);
      background-size: 40px 40px;
    }
  </style>
</html>
