---
// src/pages/index.astro
import '../styles/global.css';
import { AsciiGhost } from '../components/AsciiGhost';
import { HeroTerminal } from '../components/HeroTerminal';
import { ArchitectureDiagram } from '../components/ArchitectureDiagram';
import { SchemaWorkflowEyecatcher } from '../components/SchemaWorkflowEyecatcher';
import GitHubStars from '../components/GitHubStars';
import { DXSwiper } from '../components/DXSwiper';
import SectionHeadline from '../components/SectionHeadline.astro';
import { basePath } from '../config/nav';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/spooky/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Spooky Sync - A SurrealDB native Sync Engine" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.site} />
    <meta property="og:title" content="Spooky Sync: The SurrealDB Native Real-Time Sync Engine" />
    <meta
      property="og:description"
      content="Build local-first, offline-ready applications with Spooky Sync. Use the power of SurrealDB to synchronize data instantly across devices."
    />
    <meta property="og:image" content={new URL('/spooky/social_card.png', Astro.site)} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.site} />
    <meta
      property="twitter:title"
      content="Spooky Sync: The SurrealDB Native Real-Time Sync Engine"
    />
    <meta
      property="twitter:description"
      content="Build local-first, offline-ready applications with Spooky Sync. Use the power of SurrealDB to synchronize data instantly across devices."
    />
    <meta property="twitter:image" content={new URL('/spooky/social_card.png', Astro.site)} />
    <title>SPOOKY SYNC</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <div
      class="sticky top-0 z-50 border-b border-surface-border p-4 bg-black/80 backdrop-blur-lg transition-all duration-300"
    >
      <nav class="max-w-7xl mx-auto flex justify-between items-center gap-8">
        <a
          href="#home"
          class="font-bold text-xl tracking-tight transition-colors duration-200 hover:text-brand-400 cursor-pointer"
        >
          Spooky Sync
        </a>
        <div class="flex items-center gap-6">
          <div class="hidden md:flex items-center gap-6 text-body-sm">
            <a
              href="#features"
              class="text-text-tertiary hover:text-text-primary transition-colors duration-200"
            >
              Features
            </a>
            <a
              href="/docs"
              class="text-text-tertiary hover:text-text-primary transition-colors duration-200"
            >
              Docs
            </a>
          </div>
          <div class="flex items-center gap-4">
            <div class="hidden lg:block">
              <GitHubStars client:visible />
            </div>
          </div>
        </div>
      </nav>
    </div>
    <section
      id="home"
      class="min-h-screen flex items-center justify-center relative border-b border-white/10 py-24"
    >
      <div class="hero-grid max-w-7xl mx-auto px-8">
        {/* Left Column - Content */}
        <div class="flex flex-col justify-center space-y-6">
          <h1
            class="text-5xl lg:text-6xl font-bold text-text-primary opacity-0 animate-fade-in animation-delay-200 leading-tight"
          >
            Local-First,<br />Real-Time,<br />By Default
          </h1>

          <p
            class="text-lg text-text-tertiary opacity-0 animate-fade-in animation-delay-400 leading-relaxed"
          >
            Build local-first applications with real-time sync, offline support, and complete type
            safety.
          </p>

          <div
            class="flex flex-col sm:flex-row gap-4 opacity-0 animate-slide-up animation-delay-600"
          >
            <a
              href={`${basePath}/docs`}
              class="group relative px-8 py-3 font-semibold text-base text-white bg-black/40 border-[2px] border-brand-400/60 rounded-full transition-all duration-300 hover:border-brand-400 hover:bg-brand-500/5 hover:shadow-[0_0_35px_rgba(168,85,247,0.6),0_0_15px_rgba(168,85,247,0.4)] hover:brightness-110 text-center"
            >
              Get Started
            </a>
            <a
              href="https://github.com/mono424/spooky"
              target="_blank"
              class="px-8 py-3 border border-surface-border hover:border-text-tertiary bg-surface hover:bg-surface-elevated text-text-primary font-semibold rounded-xl transition-all duration-200 text-center"
            >
              View on Github
            </a>
          </div>
        </div>

        {/* Right Column - Terminal Window */}
        <div class="relative flex items-center justify-center lg:justify-end">
          {/* Ghost Background */}
          <div
            class="absolute top-1/2 left-1/2 -translate-x-[80%] -translate-y-1/2 opacity-0 animate-fade-in-subtle pointer-events-none z-0 scale-[3]"
          >
            <AsciiGhost client:load />
          </div>

          {/* Terminal Window */}
          <div
            class="relative z-10 scale-110 translate-x-4 opacity-0 animate-flip-in animation-delay-200"
          >
            <HeroTerminal client:load />
          </div>
        </div>
      </div>
    </section>

    <section id="features" class="pt-12 pb-24">
      <div class="max-w-7xl mx-auto px-4">
        <!-- Section Header -->
        <div class="text-center mb-16">
          <div class="mb-4">
            <span
              class="inline-block px-3 py-1.5 text-xs font-medium text-brand-400 bg-brand-500/10 border border-brand-500/30 rounded-lg"
            >
              Features
            </span>
          </div>
          <h2 class="text-section font-bold text-text-primary mb-6">
            Build Horrifyingly Great Apps
          </h2>
          <p class="text-body text-text-tertiary max-w-2xl mx-auto">
            From offline-first capabilities to real-time synchronization and complete type safety
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
          <!-- Card 1: Offline Compatibility -->
          <div
            class="group relative bg-surface border border-surface-border rounded-2xl p-8 hover:bg-surface-elevated hover:border-accent-500/30 transition-all duration-300"
          >
            <div class="flex flex-col h-full">
              <div class="mb-6">
                <div
                  class="w-12 h-12 rounded-xl bg-accent-500/10 flex items-center justify-center mb-4"
                >
                  <svg
                    class="w-6 h-6 text-accent-500"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.5"
                      d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"
                    ></path>
                  </svg>
                </div>
              </div>

              <h3 class="text-xl font-semibold text-text-primary mb-3">Offline Compatibility</h3>

              <p class="text-body-sm text-text-tertiary leading-relaxed">
                Full read/write capability without network access. Changes are queued locally and
                synchronized automatically when connectivity returns.
              </p>
            </div>
          </div>

          <!-- Card 2: Live Updates -->
          <div
            class="group relative bg-surface border border-surface-border rounded-2xl p-8 hover:bg-surface-elevated hover:border-brand-500/30 transition-all duration-300"
          >
            <div class="flex flex-col h-full">
              <div class="mb-6">
                <div
                  class="w-12 h-12 rounded-xl bg-brand-500/10 flex items-center justify-center mb-4"
                >
                  <svg
                    class="w-6 h-6 text-brand-500"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.5"
                      d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                  </svg>
                </div>
              </div>

              <h3 class="text-xl font-semibold text-text-primary mb-3">Live Updates</h3>

              <p class="text-body-sm text-text-tertiary leading-relaxed">
                Sub-millisecond latency. Data changes propagate instantly to all connected clients
                via incremental view maintenance.
              </p>
            </div>
          </div>

          <!-- Card 3: Developer Experience -->
          <div
            class="group relative bg-surface border border-surface-border rounded-2xl p-8 hover:bg-surface-elevated hover:border-brand-500/30 transition-all duration-300"
          >
            <div class="flex flex-col h-full">
              <div class="mb-6">
                <div
                  class="w-12 h-12 rounded-xl bg-brand-500/10 flex items-center justify-center mb-4"
                >
                  <svg
                    class="w-6 h-6 text-brand-500"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.5"
                      d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
                  </svg>
                </div>
              </div>

              <h3 class="text-xl font-semibold text-text-primary mb-3">Exceptional DX</h3>

              <p class="text-body-sm text-text-tertiary leading-relaxed">
                Schema-first design with end-to-end type safety. Generated TypeScript definitions
                ensure your code is always correct.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- How It Works Section -->
    <section class="py-32 border-t border-surface-border/50">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <div class="mb-4">
            <span
              class="inline-block px-3 py-1.5 text-xs font-medium text-accent-400 bg-accent-500/10 border border-accent-500/30 rounded-lg"
            >
              How It Works
            </span>
          </div>
          <h2 class="text-section font-bold text-text-primary mb-6">It feels like magic</h2>
          <p class="text-body text-text-tertiary max-w-2xl mx-auto">
            Direct state synchronization powered by SurrealDB
          </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="space-y-6">
            <div class="space-y-4">
              <h3 class="text-xl font-semibold text-text-primary">SurrealDB native sync engine</h3>
              <p class="text-body-sm text-text-tertiary leading-relaxed">
                Spooky bypasses traditional REST APIs in favor of direct state synchronization on
                top of SurrealDB. Built for modern real-time applications that need instant updates
                across all clients.
              </p>
            </div>

            <div class="space-y-4">
              <h3 class="text-xl font-semibold text-text-primary">
                Authentication-agnostic security
              </h3>
              <p class="text-body-sm text-text-tertiary leading-relaxed">
                Integrate with any identity provider while maintaining fine-grained access control.
                SurrealDB's flexible security model adapts to your authentication strategy.
              </p>
            </div>

            <div class="mt-8">
              <a
                href="https://github.com/mono424/spooky"
                target="_blank"
                class="inline-block px-6 py-3 bg-black/40 border-[2px] border-brand-400/60 text-white font-semibold rounded-full transition-all duration-300 hover:border-brand-400 hover:bg-brand-500/5 hover:shadow-[0_0_35px_rgba(168,85,247,0.6),0_0_15px_rgba(168,85,247,0.4)] hover:brightness-110"
              >
                Read Full Documentation
              </a>
            </div>
          </div>

          <div class="flex items-center justify-center">
            <ArchitectureDiagram client:visible />
          </div>
        </div>
      </div>
    </section>

    <!-- Schema-First Development Section -->
    <section class="py-16 border-t border-surface-border/50 relative">
      <!-- Visual variety background -->
      <div
        class="absolute inset-0 bg-gradient-to-b from-surface/20 to-transparent pointer-events-none"
      >
      </div>

      <div class="max-w-7xl mx-auto px-4 relative z-10">
        <SectionHeadline
          title="Schema-First Development"
          badge="Type Safety"
          description="Define your database schema once in SurrealDB, and let Spooky generate type-safe clients for all your targets—TypeScript, Dart, Zod, and more. One source of truth for your entire stack."
        />

        <SchemaWorkflowEyecatcher client:visible />
      </div>
    </section>

    <!-- Developer Experience Section with Swiper -->
    <section class="py-32 border-t border-surface-border/50">
      <div class="max-w-7xl mx-auto px-4 relative z-10">
        <SectionHeadline
          title="Exceptional DX"
          badge="Developer Tools"
          description='Spooky is built by <span class="text-text-primary">developers for developers</span> with framework-native queries with <span class="text-brand-400">full reactivity</span> and type safety.'
        />

        <DXSwiper client:visible />
      </div>
    </section>

    <!-- Architecture Section -->
    <section class="py-32 border-t border-surface-border/50">
      <div class="max-w-7xl mx-auto px-4">
        <SectionHeadline
          title="Under the Hood"
          badge="Architecture"
          description='Spooky uses <span class="text-text-primary">Incremental View Maintenance</span> to track client query hashes, known as <span class="text-brand-400 font-bold">Incantations</span>. These are stored in the <code class="bg-surface px-1.5 py-0.5 rounded text-text-secondary font-mono">_spooky_querys</code> table. Choose your runtime based on your performance needs.'
        />

        <div class="text-center mb-8">
          <p class="text-xs text-text-tertiary font-mono flex items-center justify-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"
              ></path>
            </svg>
            Scroll to explore deployment options
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"
              ></path>
            </svg>
          </p>
        </div>

        <div class="architecture-scroll-wrapper">
          <div class="architecture-scroll-container">
            <div
              class="group border border-surface-border bg-surface hover:border-accent-500/30 hover:shadow-xl transition-all duration-300 relative overflow-hidden rounded-2xl flex flex-col architecture-box"
            >
              <!-- Gradient header banner -->
              <div class="h-1.5 w-full bg-gradient-to-r from-accent-500 to-accent-600"></div>

              <div class="p-8 flex-1 flex flex-col relative z-10">
                <div class="flex justify-between items-baseline mb-6">
                  <h3 class="text-xl font-bold text-text-primary">SSP Singlenode</h3>
                  <span
                    class="text-xs font-medium bg-accent-500/10 border border-accent-500/30 text-accent-400 px-3 py-1 rounded-lg"
                    >Development</span
                  >
                </div>

                <div class="w-full flex flex-col gap-4 font-mono mb-8">
                  <!-- CLIENTS LAYER -->
                  <div class="flex justify-center gap-8 relative z-10">
                    <div class="flex flex-col items-center gap-1 group/client">
                      <div
                        class="h-8 w-8 border border-gray-600 rounded bg-surface-elevated flex items-center justify-center text-gray-400 group-hover/client:border-white group-hover/client:text-white transition-colors"
                      >
                        <span class="text-[10px]">WEB</span>
                      </div>
                      <span class="text-[8px] text-gray-600">React/Solid</span>
                      <div
                        class="w-[1px] h-full bg-gradient-to-b from-transparent via-gray-700 to-gray-700"
                      >
                      </div>
                    </div>
                    <div class="flex flex-col items-center gap-1 group/client">
                      <div
                        class="h-8 w-8 border border-gray-600 rounded bg-surface-elevated flex items-center justify-center text-gray-400 group-hover/client:border-white group-hover/client:text-white transition-colors"
                      >
                        <span class="text-[10px]">APP</span>
                      </div>
                      <span class="text-[8px] text-gray-600">Flutter/iOS</span>
                      <div
                        class="w-[1px] h-full bg-gradient-to-b from-transparent via-gray-700 to-gray-700"
                      >
                      </div>
                    </div>
                  </div>

                  <!-- INFRASTRUCTURE BOX -->
                  <div
                    class="border border-dashed border-surface-border p-3 rounded bg-surface-elevated relative mt-2"
                  >
                    <div
                      class="absolute -top-2 left-3 bg-surface px-1 text-[8px] text-gray-500 font-bold uppercase tracking-wider"
                    >
                      Server Infrastructure
                    </div>

                    <div class="flex gap-2">
                      <!-- SURREALDB NODE -->
                      <div
                        class="flex-1 border border-blue-900/40 bg-blue-900/5 p-2 rounded flex flex-col gap-2"
                      >
                        <div
                          class="flex items-center justify-between border-b border-blue-900/20 pb-1"
                        >
                          <span class="text-[9px] font-bold text-blue-400">SURREALDB</span>
                          <span class="h-1.5 w-1.5 rounded-full bg-blue-500 animate-pulse"></span>
                        </div>
                        <div class="space-y-1">
                          <div
                            class="bg-blue-900/10 border border-blue-900/20 px-1.5 py-1 rounded text-[8px] text-blue-200/70"
                          >
                            Tables & Auth
                          </div>
                          <div
                            class="bg-blue-900/10 border border-blue-900/20 px-1.5 py-1 rounded text-[8px] text-blue-200/70"
                          >
                            Live Query Hub
                          </div>
                          <div
                            class="bg-blue-900/10 border border-blue-900/20 px-1.5 py-1 rounded text-[8px] text-blue-200/70"
                          >
                            Event Triggers
                          </div>
                        </div>
                      </div>

                      <!-- RPC CONNECT -->
                      <div
                        class="flex flex-col justify-center items-center gap-0.5 text-[8px] text-gray-600 w-8 shrink-0"
                      >
                        <span>RPC</span>
                        <div class="w-full h-[1px] bg-gray-700"></div>
                        <span>SYNC</span>
                      </div>

                      <!-- SIDECAR NODE -->
                      <div
                        class="flex-1 border border-green-900/40 bg-green-900/10 p-2 rounded shadow-[0_0_20px_rgba(22,197,94,0.05)] flex flex-col gap-2"
                      >
                        <div
                          class="flex items-center justify-between border-b border-green-900/20 pb-1"
                        >
                          <span class="text-[9px] font-bold text-green-400">SSP</span>
                          <span
                            class="h-1.5 w-1.5 rounded-full bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.8)]"
                          ></span>
                        </div>
                        <div class="space-y-1">
                          <div
                            class="bg-green-900/20 border border-green-900/30 px-1.5 py-1 rounded text-[8px] text-green-200/80 font-bold flex items-center gap-1"
                          >
                            <span>⚡</span> DBSP Engine
                          </div>
                          <div
                            class="bg-green-900/20 border border-green-900/30 px-1.5 py-1 rounded text-[8px] text-green-200/80"
                          >
                            Incantation Mgr
                          </div>
                          <div
                            class="bg-green-900/20 border border-green-900/30 px-1.5 py-1 rounded text-[8px] text-green-200/80"
                          >
                            In-Memory State
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="mt-auto">
                  <p class="text-xs text-gray-500 mb-4 font-mono leading-relaxed">
                    The Sidecar runs as a separate process. It keeps the DBSP state in <span
                      class="text-gray-300">RAM</span
                    >, eliminating the need to save/load state on every request. It updates the
                    database via RPC.
                  </p>
                  <ul
                    class="space-y-2 font-mono text-xs text-gray-500 border-t border-surface-border pt-4"
                  >
                    <li
                      class="flex items-start gap-2 transition-colors duration-300 hover:text-gray-300"
                    >
                      <svg
                        class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M5 13l4 4L19 7"></path>
                      </svg>
                      <span>High Performance (In-Memory State).</span>
                    </li>
                    <li
                      class="flex items-start gap-2 transition-colors duration-300 hover:text-gray-300"
                    >
                      <svg
                        class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M5 13l4 4L19 7"></path>
                      </svg>
                      <span>Scalable for production loads.</span>
                    </li>
                  </ul>
                </div>
              </div>
            </div>

            <!-- SSP CLUSTER BOX -->
            <div
              class="group border border-surface-border bg-surface hover:border-orange-500/30 hover:shadow-xl transition-all duration-300 relative overflow-hidden rounded-2xl flex flex-col architecture-box-wide"
            >
              <!-- Gradient header banner -->
              <div class="h-1.5 w-full bg-gradient-to-r from-orange-500 to-yellow-600"></div>

              <div class="p-8 flex-1 flex flex-col relative z-10">
                <div class="flex justify-between items-baseline mb-6">
                  <h3 class="text-xl font-bold text-text-primary">SSP Cluster</h3>
                  <span
                    class="text-xs font-medium bg-orange-500/10 border border-orange-500/30 text-orange-400 px-3 py-1 rounded-lg"
                    >Production</span
                  >
                </div>

                <div class="w-full flex flex-col gap-4 font-mono mb-8">
                  <!-- CLIENTS LAYER -->
                  <div class="flex justify-center gap-8 relative z-10">
                    <div class="flex flex-col items-center gap-1 group/client">
                      <div
                        class="h-8 w-8 border border-gray-600 rounded bg-surface-elevated flex items-center justify-center text-gray-400 group-hover/client:border-white group-hover/client:text-white transition-colors"
                      >
                        <span class="text-[10px]">WEB</span>
                      </div>
                      <span class="text-[8px] text-gray-600">React/Vue</span>
                      <div
                        class="w-[1px] h-full bg-gradient-to-b from-transparent via-gray-700 to-gray-700"
                      >
                      </div>
                    </div>
                    <div class="flex flex-col items-center gap-1 group/client">
                      <div
                        class="h-8 w-8 border border-gray-600 rounded bg-surface-elevated flex items-center justify-center text-gray-400 group-hover/client:border-white group-hover/client:text-white transition-colors"
                      >
                        <span class="text-[10px]">APP</span>
                      </div>
                      <span class="text-[8px] text-gray-600">Flutter/iOS</span>
                      <div
                        class="w-[1px] h-full bg-gradient-to-b from-transparent via-gray-700 to-gray-700"
                      >
                      </div>
                    </div>
                    <div class="flex flex-col items-center gap-1 group/client">
                      <div
                        class="h-8 w-8 border border-gray-600 rounded bg-surface-elevated flex items-center justify-center text-gray-400 group-hover/client:border-white group-hover/client:text-white transition-colors"
                      >
                        <span class="text-[10px]">API</span>
                      </div>
                      <span class="text-[8px] text-gray-600">Backend</span>
                      <div
                        class="w-[1px] h-full bg-gradient-to-b from-transparent via-gray-700 to-gray-700"
                      >
                      </div>
                    </div>
                  </div>

                  <!-- INFRASTRUCTURE BOX -->
                  <div
                    class="border border-dashed border-surface-border p-3 rounded bg-surface-elevated relative mt-2"
                  >
                    <div
                      class="absolute -top-2 left-3 bg-surface px-1 text-[8px] text-gray-500 font-bold uppercase tracking-wider"
                    >
                      Enterprise Infrastructure
                    </div>

                    <div class="flex gap-2">
                      <!-- SURREALDB NODE -->
                      <div
