        content: 'Click to collapse';
      }

      .schema-details .expand-text {
        font-size: 0;
      }

      .schema-details .expand-text::before {
        font-size: 1rem;
      }

      /* Professional expand animation */
      @keyframes expand-in {
        from {
          opacity: 0;
          transform: translateY(-8px);
          max-height: 0;
        }
        to {
          opacity: 1;
          transform: translateY(0);
          max-height: 2000px;
        }
      }

      .schema-details[open] .expanded-content {
        animation: expand-in 0.5s cubic-bezier(0.4, 0, 0.2, 1);
      }

      /* Subtle pulse animation for badge */
      @keyframes pulse-subtle {
        0%,
        100% {
          opacity: 1;
        }
        50% {
          opacity: 0.8;
        }
      }

      .animate-pulse-subtle {
        animation: pulse-subtle 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
      }

      /* Micro-interactions for code blocks */
      .schema-details summary > div > div > div > div {
        transition:
          transform 0.2s ease,
          box-shadow 0.2s ease;
      }

      .schema-details summary:hover > div > div > div > div {
        transform: translateY(-1px);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
      }
    </style>
  </body>
</html>
