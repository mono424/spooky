---
// oxlint-disable-next-line no-unassigned-import
import '../styles/global.css';
import { TeamGrid } from '../components/TeamGrid';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Meet the team behind sp00ky" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.site + 'team'} />
    <meta property="og:title" content="Team — sp00ky" />
    <meta property="og:description" content="Meet the team behind sp00ky" />
    <meta property="og:image" content={new URL('/social-card.png', Astro.site)} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content="Team — sp00ky" />
    <meta property="twitter:description" content="Meet the team behind sp00ky" />
    <meta property="twitter:image" content={new URL('/social-card.png', Astro.site)} />
    <title>Team — sp00ky</title>
  </head>

  <body class="min-h-screen flex flex-col">
    <SiteNav activePath="/team" />

    <main class="relative flex-1">
      <section class="pt-24 pb-0 md:pt-32 md:pb-0">
        <div class="max-w-5xl mx-auto px-4">
          <h1
            class="text-section md:text-hero font-semibold text-text-primary mb-6 opacity-0 animate-fade-in animation-delay-200"
          >
            Built by people<br />
            <span class="text-text-tertiary">who ship.</span>
          </h1>
          <p
            class="text-body-lg text-text-muted max-w-xl mb-16 opacity-0 animate-fade-in animation-delay-400"
          >
            A small team obsessed with developer experience.
          </p>
        </div>
      </section>

      <section class="pb-16 md:pb-24">
        <TeamGrid client:load />
      </section>
    </main>

    <SiteFooter />
  </body>
</html>
