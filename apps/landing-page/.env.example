# Loops form URL. Sign up at https://loops.so, create a form, paste the URL here.
# The frontend POSTs form-encoded `email` to this URL. Same shape works for
# Buttondown, Mailchimp, ConvertKit, Formspree if you prefer one of those.
PUBLIC_NEWSLETTER_ENDPOINT=https://app.loops.so/api/newsletter-form/REPLACE-ME
